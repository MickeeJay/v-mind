{
  "name": "v-mind",
  "version": "0.1.0",
  "private": true,
  "description": "Bitcoin L2 DeFi strategy automation platform built on Stacks blockchain",
  "workspaces": [
    "contracts",
    "agent",
    "web"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev:agent\" \"npm run dev:web\"",
    "dev:agent": "npm run dev --workspace=agent",
    "dev:web": "npm run dev --workspace=web",
    "dev:contracts": "npm run dev --workspace=contracts",
    "build": "npm run build --workspaces --if-present",
    "build:agent": "npm run build --workspace=agent",
    "build:web": "npm run build --workspace=web",
    "test": "npm run test --workspaces --if-present",
    "test:agent": "npm run test --workspace=agent",
    "test:web": "npm run test --workspace=web",
    "test:contracts": "npm run test --workspace=contracts",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "stacks",
    "bitcoin",
    "l2",
    "defi",
    "automation",
    "clarinet"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/v-mind.git"
  },
  "author": "",
  "license": "MIT"
}
