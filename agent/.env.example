# ============================================================================
# V-Mind Agent Service - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file - it contains sensitive credentials

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Node environment: development, production, test
NODE_ENV=development

# Application port
PORT=3001

# Application host
HOST=localhost

# API version prefix
API_VERSION=v1

# ============================================================================
# STACKS BLOCKCHAIN CONFIGURATION
# ============================================================================
# Stacks network: mainnet, testnet, devnet
STACKS_NETWORK=testnet

# Stacks node RPC URL
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.mainnet.hiro.so
# Local: http://localhost:3999
STACKS_NODE_URL=https://api.testnet.hiro.so

# Deployer Stacks address (derived from private key)
# This is the address that will deploy and manage contracts
STACKS_DEPLOYER_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Stacks private key for deployer (SENSITIVE - never commit real value)
# Used for signing transactions and contract deployments
STACKS_PRIVATE_KEY=your_stacks_private_key_here_64_hex_characters

# ============================================================================
# EXTERNAL API CONFIGURATION
# ============================================================================
# Hiro API base URL for additional Stacks data
# Provides transaction history, account info, and token metadata
HIRO_API_BASE_URL=https://api.testnet.hiro.so

# Hiro API key for higher rate limits (optional)
# Get your key at: https://platform.hiro.so
HIRO_API_KEY=your_hiro_api_key_here

# AI Inference API endpoint for strategy analysis
# Used for intelligent DeFi strategy recommendations
AI_INFERENCE_API_URL=https://api.openai.com/v1

# AI Inference API key (SENSITIVE - never commit real value)
AI_INFERENCE_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string (SENSITIVE - contains credentials)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://vmind_user:your_password_here@localhost:5432/vmind_db

# Database connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Database SSL mode: disable, require, verify-ca, verify-full
DATABASE_SSL_MODE=disable

