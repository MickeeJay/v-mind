# V-Mind autonomous agent runtime configuration.
# Copy to `.env` and provide production values.

NODE_ENV=development
LOG_LEVEL=info

# Required.
STACKS_NETWORK=testnet
STACKS_API_BASE_URL=https://api.testnet.hiro.so
STACKS_PRIVATE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional.
HIRO_API_KEY=

AGENT_POLL_INTERVAL_MS=10000
AGENT_LOG_EVERY_N_BLOCKS=5

RPC_RETRY_ATTEMPTS=4
RPC_RETRY_MIN_TIMEOUT_MS=250
RPC_RETRY_MAX_TIMEOUT_MS=5000

SHUTDOWN_TIMEOUT_MS=20000
HEALTHCHECK_PORT=9090

