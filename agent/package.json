{
  "name": "@v-mind/agent",
  "version": "0.1.0",
  "private": true,
  "description": "V-Mind backend agent service for DeFi strategy automation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stacks/blockchain-api-client": "7.8.2",
    "@stacks/network": "6.17.0",
    "@stacks/stacks-blockchain-api-types": "^7.8.2",
    "@stacks/transactions": "6.13.1",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@vitest/coverage-v8": "^1.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
