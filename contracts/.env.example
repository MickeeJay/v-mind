# ============================================================================
# V-Mind Contracts - Environment Configuration
# ============================================================================
# Used for contract deployment and interaction scripts
# NEVER commit the .env file - it contains your mnemonic and private keys

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Stacks network target: mainnet, testnet, devnet
STACKS_NETWORK=testnet

# Stacks node URL for deployment
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.mainnet.hiro.so
STACKS_NODE_URL=https://api.testnet.hiro.so

# Optional explicit path to deployment config JSON
# Defaults to deployments/config/<STACKS_NETWORK>.json
DEPLOY_CONFIG_PATH=deployments/config/testnet.json

# Optional explicit path where deployment manifest should be written
# If not set, a timestamped file in deployments/manifests is used
DEPLOYMENT_MANIFEST_PATH=

# Optional Clarinet simnet URL used when running deploy:dry-run
CLARINET_SIMNET_URL=http://127.0.0.1:3999

# ============================================================================
# DEPLOYER CREDENTIALS (SENSITIVE - NEVER COMMIT REAL VALUES)
# ============================================================================
# WARNING: These are EXTREMELY SENSITIVE credentials
# Your mnemonic gives full control over your Stacks account
# NEVER share, commit, or expose these values

# 24-word mnemonic phrase for deployer account
# Example: word1 word2 word3 ... word24
# Generate a new one at: https://www.blockplate.com/pages/bip-39-generate-mnemonic
DEPLOYER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Alternative: Deployer private key (64 hex characters)
# Use either mnemonic OR private key, not both
DEPLOYER_PRIVATE_KEY=your_64_character_hex_private_key_here

# Deployer Stacks address (derived from mnemonic/private key)
# Used to verify correct credentials
DEPLOYER_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================
# Contract name to deploy

# Gas price in microSTX (1 STX = 1,000,000 microSTX)
GAS_PRICE=1000

# Fee multiplier for faster confirmation
FEE_MULTIPLIER=1.5

# Deployment confirmation timeout in seconds
DEPLOYMENT_TIMEOUT=600

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================
# Enable verbose test output
TEST_VERBOSE=true

# Test coverage threshold percentage
TEST_COVERAGE_THRESHOLD=80

# Enable gas usage reporting in tests
TEST_GAS_REPORTING=true

