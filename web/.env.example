# ============================================================================
# V-Mind Web Application - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# NEVER commit .env.local - it contains sensitive values

# ============================================================================
# NEXT.JS CONFIGURATION
# ============================================================================
# Node environment
NODE_ENV=development

# ============================================================================
# STACKS BLOCKCHAIN CONFIGURATION (PUBLIC)
# ============================================================================
# Stacks network: mainnet, testnet, devnet
# This is exposed to the browser for wallet connections
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Stacks API URL (public)
# Used by Stacks wallet libraries in the browser
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Contract deployer address (public)
# Used to identify our deployed contracts
NEXT_PUBLIC_DEPLOYER_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Main contract name (public)
NEXT_PUBLIC_CONTRACT_NAME=v-mind-core

