# ============================================================================
# V-Mind Web Application - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# NEVER commit .env.local - it contains sensitive values

# ============================================================================
# NEXT.JS CONFIGURATION
# ============================================================================
# Node environment
NODE_ENV=development

# ============================================================================
# STACKS BLOCKCHAIN CONFIGURATION (PUBLIC)
# ============================================================================
# Stacks network: mainnet, testnet, devnet
# This is exposed to the browser for wallet connections
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Stacks API URL (public)
# Used by Stacks wallet libraries in the browser
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Contract deployer address (public)
# Used to identify our deployed contracts
NEXT_PUBLIC_DEPLOYER_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Main contract name (public)
NEXT_PUBLIC_CONTRACT_NAME=v-mind-core

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Agent service API base URL
# Points to the backend agent service
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API version
NEXT_PUBLIC_API_VERSION=v1

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# ============================================================================
# FEATURE FLAGS (PUBLIC)
# ============================================================================
# Enable beta features
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Enable advanced strategy builder
NEXT_PUBLIC_ENABLE_ADVANCED_STRATEGIES=false

# Enable analytics tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable mainnet mode (use with caution)
NEXT_PUBLIC_ENABLE_MAINNET=false

# ============================================================================
# ANALYTICS & MONITORING (PUBLIC)
# ============================================================================
# Google Analytics ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog API key (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here

# PostHog API host
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
# Enable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Build ID for version tracking
NEXT_PUBLIC_BUILD_ID=local-dev

# Git commit SHA for deployment tracking
NEXT_PUBLIC_GIT_SHA=development

